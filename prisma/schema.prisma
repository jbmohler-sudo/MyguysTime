generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  fullName       String
  passwordHash   String
  role           String
  employeeId     String?         @unique
  employee       Employee?       @relation(fields: [employeeId], references: [id])
  createdReports PrivateReport[] @relation("PrivateReportAuthor")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Company {
  id                           String                 @id @default(cuid())
  companyName                  String
  stateCode                    String
  payrollDisclaimerAcceptedAt  DateTime?
  payrollDisclaimerAcceptedByUserId String?
  payrollDisclaimerVersion     String?
  createdAt                    DateTime               @default(now())
  updatedAt                    DateTime               @updatedAt
  payrollSettings              CompanyPayrollSettings?
}

model Crew {
  id           String           @id @default(cuid())
  name         String
  foremanId    String?
  foreman      Employee?        @relation("ForemanCrew", fields: [foremanId], references: [id])
  defaultEmployees Employee[]   @relation("DefaultCrew")
  assignments  CrewAssignment[]
  dayDefaults  CrewDayDefault[]
  timesheets   TimesheetWeek[]
  reports      PrivateReport[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model Employee {
  id                String             @id @default(cuid())
  firstName         String
  lastName          String
  displayName       String
  employmentStatus  String             @default("ACTIVE")
  hourlyRateCents   Int
  overtimeRateCents Int?
  usesCompanyFederalDefault Boolean    @default(true)
  usesCompanyStateDefault   Boolean    @default(true)
  federalWithholdingPercent Float      @default(0.10)
  stateWithholdingPercent   Float      @default(0.03)
  defaultCrewId     String?
  archiveReason     String?
  archiveNotes      String?
  archivedAt        DateTime?
  rehiredAt         DateTime?
  user              User?
  defaultCrew       Crew?              @relation("DefaultCrew", fields: [defaultCrewId], references: [id])
  foremanForCrew    Crew[]             @relation("ForemanCrew")
  assignments       CrewAssignment[]
  timesheets        TimesheetWeek[]
  adjustments       WeeklyAdjustment[]
  payrollEstimates  PayrollEstimate[]
  reports           PrivateReport[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model CompanyPayrollSettings {
  id                             String   @id @default(cuid())
  companyId                      String   @unique
  defaultFederalWithholdingMode  String   @default("PERCENTAGE")
  defaultFederalWithholdingValue Float    @default(0.10)
  defaultStateWithholdingMode    String   @default("PERCENTAGE")
  defaultStateWithholdingValue   Float    @default(0.03)
  payrollPrepDisclaimer          String?
  pfmlEnabled                    Boolean  @default(false)
  pfmlEmployeeRate               Float    @default(0)
  extraWithholdingLabel          String?
  extraWithholdingRate           Float?
  supportLevelSnapshot           String   @default("PARTIAL_MANUAL")
  company                        Company  @relation(fields: [companyId], references: [id])
  createdAt                      DateTime @default(now())
  updatedAt                      DateTime @updatedAt
}

model StatePayrollRule {
  id                           String   @id @default(cuid())
  stateCode                    String   @unique
  stateName                    String
  supportLevel                 String
  hasStateIncomeTax            Boolean  @default(true)
  hasExtraEmployeeWithholdings Boolean  @default(false)
  extraWithholdingTypes        String?
  defaultStateWithholdingMode  String   @default("PERCENTAGE")
  defaultStateWithholdingValue Float    @default(0)
  defaultPfmlEnabled           Boolean  @default(false)
  defaultPfmlEmployeeRate      Float    @default(0)
  notes                        String?
  disclaimerText               String?
  lastReviewedAt               DateTime?
  sourceLabel                  String?
  sourceUrl                    String?
  isActive                     Boolean  @default(true)
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt
}

model CrewAssignment {
  id         String   @id @default(cuid())
  crewId     String
  employeeId String
  startsOn   DateTime
  endsOn     DateTime?
  crew       Crew     @relation(fields: [crewId], references: [id])
  employee   Employee @relation(fields: [employeeId], references: [id])
  createdAt  DateTime @default(now())

  @@index([crewId, startsOn])
  @@index([employeeId, startsOn])
}

model CrewDayDefault {
  id               String   @id @default(cuid())
  crewId           String
  weekStartDate    DateTime
  dayIndex         Int
  startTimeMinutes Int?
  endTimeMinutes   Int?
  crew             Crew     @relation(fields: [crewId], references: [id])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([crewId, weekStartDate, dayIndex])
}

model TimesheetWeek {
  id                    String          @id @default(cuid())
  employeeId            String
  crewId                String
  weekStartDate         DateTime
  status                String          @default("DRAFT")
  submittedByEmployeeAt DateTime?
  reviewedByForemanAt   DateTime?
  lockedAt              DateTime?
  exportedAt            DateTime?
  exportedByUserId      String?
  employee              Employee        @relation(fields: [employeeId], references: [id])
  crew                  Crew            @relation(fields: [crewId], references: [id])
  dayEntries            TimeEntryDay[]
  adjustment            WeeklyAdjustment?
  payrollEstimate       PayrollEstimate?
  statusAuditEvents     TimesheetStatusAudit[]
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@unique([employeeId, weekStartDate])
  @@index([crewId, weekStartDate])
}

model TimesheetStatusAudit {
  id              String        @id @default(cuid())
  timesheetWeekId String
  fromStatus      String
  toStatus        String
  note            String?
  createdByUserId String
  createdAt       DateTime      @default(now())
  timesheetWeek   TimesheetWeek @relation(fields: [timesheetWeekId], references: [id])
}

model TimeEntryDay {
  id                String        @id @default(cuid())
  timesheetWeekId   String
  dayIndex          Int
  workDate          DateTime
  startTimeMinutes  Int?
  endTimeMinutes    Int?
  lunchMinutes      Int           @default(0)
  totalMinutes      Int           @default(0)
  jobTag            String?
  employeeConfirmed Boolean       @default(false)
  timesheetWeek     TimesheetWeek @relation(fields: [timesheetWeekId], references: [id])
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@unique([timesheetWeekId, dayIndex])
}

model WeeklyAdjustment {
  id                    String        @id @default(cuid())
  employeeId            String
  timesheetWeekId       String        @unique
  gasReimbursementCents Int           @default(0)
  pettyCashCents        Int           @default(0)
  deductionCents        Int           @default(0)
  note                  String?
  employee              Employee      @relation(fields: [employeeId], references: [id])
  timesheetWeek         TimesheetWeek @relation(fields: [timesheetWeekId], references: [id])
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
}

model PayrollEstimate {
  id                      String          @id @default(cuid())
  employeeId              String
  timesheetWeekId         String          @unique
  regularMinutes          Int
  overtimeMinutes         Int
  grossPayCents           Int
  federalWithholdingMode  String          @default("PERCENTAGE")
  federalWithholdingValue Float
  stateWithholdingMode    String          @default("PERCENTAGE")
  stateWithholdingValue   Float
  federalWithholdingCents Int
  stateWithholdingCents   Int
  pfmlWithholdingCents    Int             @default(0)
  extraStateWithholdingLabel String?
  extraStateWithholdingCents Int          @default(0)
  manualNetOverrideCents  Int?
  netCheckEstimateCents   Int
  employee                Employee        @relation(fields: [employeeId], references: [id])
  timesheetWeek           TimesheetWeek   @relation(fields: [timesheetWeekId], references: [id])
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
}

model PrivateReport {
  id                 String         @id @default(cuid())
  employeeId         String
  crewId             String
  reportDate         DateTime
  jobTag             String?
  category           String
  severity           String
  factualDescription String
  followUpStatus     String         @default("OPEN")
  createdByUserId    String
  employee           Employee       @relation(fields: [employeeId], references: [id])
  crew               Crew           @relation(fields: [crewId], references: [id])
  createdByUser      User           @relation("PrivateReportAuthor", fields: [createdByUserId], references: [id])
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([employeeId, reportDate])
  @@index([crewId, reportDate])
}
